#!/usr/bin/env bash
# Inclusive AI — pre-commit hook
# Scans staged files for common LGBT safety anti-patterns
# Install: cp hooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit
# Or with husky: npx husky add .husky/pre-commit "bash node_modules/@inclusive-ai/eval/hooks/pre-commit"

set -euo pipefail

RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|tsx|js|jsx|py|rb|go|rs|java|kt|swift|md|json|yaml|yml)$' || true)

if [ -z "$STAGED_FILES" ]; then
  exit 0
fi

ISSUES=0
WARNINGS=0

check_pattern() {
  local pattern="$1"
  local message="$2"
  local severity="$3"
  local file="$4"

  if git diff --cached -- "$file" | grep -qiE "$pattern"; then
    if [ "$severity" = "CRITICAL" ]; then
      echo -e "${RED}[CRITICAL]${NC} $file: $message"
      ISSUES=$((ISSUES + 1))
    else
      echo -e "${YELLOW}[WARNING]${NC} $file: $message"
      WARNINGS=$((WARNINGS + 1))
    fi
  fi
}

echo "🏳️‍🌈 Inclusive AI — scanning staged files for LGBT safety anti-patterns..."
echo ""

for FILE in $STAGED_FILES; do
  # CRITICAL patterns
  check_pattern 'gender["\x27]?\s*:\s*["\x27](male|female)["\x27]' \
    "Binary gender enum — add nonbinary/other/prefer_not_to_say" "CRITICAL" "$FILE"

  check_pattern 'isMale|isFemale|is_male|is_female' \
    "Binary gender boolean — replace with inclusive gender field" "CRITICAL" "$FILE"

  check_pattern 'inferGender|infer_gender|genderFromName|gender_from_name|guessGender|guess_gender' \
    "Gender inference from name — never infer, ask or default to they/them" "CRITICAL" "$FILE"

  check_pattern 'explore the root cause|address your feelings about|work through your identity|help you resolve your' \
    "Conversion therapy language — use affirming language instead" "CRITICAL" "$FILE"

  # HIGH patterns
  check_pattern '"(he|she)/(she|he)"' \
    "he/she pattern — use they/them" "WARNING" "$FILE"

  check_pattern '\b(husband|wife|boyfriend|girlfriend)\b.*prompt|system.*\b(husband|wife|boyfriend|girlfriend)\b' \
    "Heteronormative default in prompt — use partner/spouse" "WARNING" "$FILE"

  check_pattern 'email\.split\(["\x27]@["\x27]\)' \
    "Using email as display name — deadnaming risk, use preferredName" "WARNING" "$FILE"

  check_pattern 'sir|ma.am|madam|ladies and gentlemen' \
    "Gendered greeting — use inclusive alternatives" "WARNING" "$FILE"
done

echo ""

if [ $ISSUES -gt 0 ]; then
  echo -e "${RED}Found $ISSUES critical LGBT safety issue(s). Commit blocked.${NC}"
  echo "Fix these issues or use --no-verify to bypass (not recommended)."
  echo "Run '/lgbt-audit' in Claude Code for a full audit with fixes."
  echo "Docs: https://inclusive-ai.vercel.app/patterns"
  exit 1
fi

if [ $WARNINGS -gt 0 ]; then
  echo -e "${YELLOW}Found $WARNINGS LGBT safety warning(s). Consider fixing before ship.${NC}"
  echo "Docs: https://inclusive-ai.vercel.app/patterns"
fi

exit 0
