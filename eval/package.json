{
  "name": "@inclusive-ai/eval",
  "version": "0.1.0",
  "description": "LGBT safety eval suite for LLM engineers — catch harms before you ship",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "inclusive-eval": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format esm,cjs --dts --clean",
    "dev": "tsup src/index.ts src/cli.ts --format esm,cjs --dts --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["llm", "safety", "lgbt", "eval", "inclusive", "bias", "testing", "anthropic", "openai"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/InclusiveCode/inclusive-ai"
  },
  "homepage": "https://inclusive-ai.vercel.app",
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": ">=0.20.0"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/sdk": { "optional": true }
  }
}
